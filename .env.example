# ---------------------------------------------------------------------------
# CloakBrowser Manager - environment configuration
# Copy this file to ".env" and edit values as needed.
# All variables are optional; defaults are shown below.
# ---------------------------------------------------------------------------

# Directory where profile data and the SQLite database are stored.
# Docker default: /data  |  Windows local dev: ./data
DATA_DIR=/data

# Optional Bearer token to protect the web UI and API.
# Leave empty to disable authentication (local dev only).
AUTH_TOKEN=

# Port the backend (FastAPI/uvicorn) listens on.
PORT=8080

# Host the backend binds to. Use 0.0.0.0 to allow remote access.
HOST=127.0.0.1
